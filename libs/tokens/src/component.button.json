{
  "component": {
    "button": {
      "primary": {
        "background":         { "$value": "{color.gray.white}", "$type": "color", "$description": "Always light — designed for dark surfaces" },
        "backgroundHover":    { "$value": "{color.gray.100}",   "$type": "color" },
        "backgroundPressed":  { "$value": "{color.gray.200}",   "$type": "color" },
        "text":               { "$value": "{color.gray.black}", "$type": "color" }
      },
      "secondary": {
        "background":         { "$value": "{color.gray.950}",   "$type": "color", "$description": "Always dark — high contrast on any surface" },
        "backgroundHover":    { "$value": "{color.gray.900}",   "$type": "color" },
        "backgroundPressed":  { "$value": "{color.gray.800}",   "$type": "color" },
        "text":               { "$value": "{color.gray.white}", "$type": "color" }
      },
      "tertiary": {
        "background":         { "$value": "{color.gray.900}",   "$type": "color" },
        "backgroundHover":    { "$value": "{color.gray.800}",   "$type": "color" },
        "backgroundPressed":  { "$value": "{color.gray.700}",   "$type": "color" },
        "text":               { "$value": "{color.gray.white}", "$type": "color" }
      },
      "outlined": {
        "background":         { "$value": "transparent",        "$type": "color" },
        "border":             { "$value": "{semantic.light.border.strong}", "$type": "color" },
        "text":               { "$value": "{semantic.light.content.primary}", "$type": "color" }
      },
      "outlinedStocks": {
        "background":         { "$value": "transparent",        "$type": "color" },
        "border":             { "$value": "{semantic.light.border.brandStocks}", "$type": "color" },
        "text":               { "$value": "{semantic.light.content.stocks}", "$type": "color" }
      },
      "outlinedBrand": {
        "background":         { "$value": "transparent",        "$type": "color" },
        "border":             { "$value": "{semantic.light.border.selected}", "$type": "color" },
        "text":               { "$value": "{semantic.light.content.brand}", "$type": "color" }
      },
      "disabled": {
        "text":               { "$value": "{semantic.light.content.disabled}", "$type": "color" },
        "border":             { "$value": "{semantic.light.border.disabled}", "$type": "color" }
      }
    }
  }
}
